# NVIDIA NIM API Keys
# Add as many as you have: _1, _2, _3 ...
NVIDIA_NIM_API_KEY_1=nvapi-your-first-key
NVIDIA_NIM_API_KEY_2=nvapi-your-second-key

# LiteLLM Master Key (used to authenticate requests to the proxy)
# Generate a random key, e.g.: python -c "import secrets; print('sk-' + secrets.token_hex(16))"
LITELLM_MASTER_KEY=sk-your-random-key
